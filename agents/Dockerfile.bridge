FROM node:22-alpine AS deps
WORKDIR /app
RUN apk add --no-cache python3 make g++
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev 2>/dev/null || npm install --omit=dev --legacy-peer-deps

FROM node:22-alpine AS production
RUN apk add --no-cache tini curl
RUN addgroup -g 1001 -S heady && \
    adduser -S heady -u 1001 -G heady
WORKDIR /app
COPY --from=deps --chown=heady:heady /app/node_modules ./node_modules
COPY --chown=heady:heady . .
USER heady

ENV NODE_ENV=production
ENV PORT=3302

EXPOSE 3302

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
  CMD curl -sf http://localhost:3302/health || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "index.js"]
