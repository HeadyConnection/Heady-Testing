# =============================================================================
# HEADY ECOSYSTEM — OPTIMIZED .env CONFIGURATION
# Generated: 2026-03-19 | Based on Deep Structural Audit Findings
# Maintainer: Eric Head <eric@headyconnection.org>
# =============================================================================
# SECURITY NOTICE: All secret values are replaced with REPLACE_WITH_* placeholders.
#   Generate secrets with: openssl rand -hex 32
#   Store actual values in GCP Secret Manager or equivalent vault.
# =============================================================================


# =============================================================================
# §1 CORE RUNTIME
# =============================================================================
NODE_ENV=production
PORT=3301
HOST=0.0.0.0
LOG_LEVEL=warn                          # OPTIMIZED: was info — warn reduces sensitive context leakage in structured JSON logs
LOG_FORMAT=json
LOG_REDACTION=true
HEADY_LOG_PRETTY=false
HEADY_ENV=production
HEADY_VERSION=3.0.0
HEADY_INSTANCE_ID=heady-prod-01
TIMEZONE=America/Denver


# =============================================================================
# §2 GITHUB
