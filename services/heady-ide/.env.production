# HeadyAI-IDE Server — Production Environment
# Derived from HEADY_ENV_v9 master config
# DO NOT commit secrets — use GCP Secret Manager for API keys

NODE_ENV=production
PORT=8080
SERVE_STATIC=true
LOG_LEVEL=info

# ─── Cloud Run ────────────────────────────────────────────────────
GCP_PROJECT_ID=headyme-444017
GCP_REGION=us-central1
CLOUD_RUN_URL=https://headyme-site-667608982461.us-central1.run.app

# ─── Cloudflare ───────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=8b1fa38f282c691423c6399247d53323
CF_AI_GATEWAY=heady-gateway

# ─── Database (Neon Postgres) ─────────────────────────────────────
NEON_HOST=ep-cold-snow-aesmiwt9.us-east-2.aws.neon.tech
NEON_USER=heady
NEON_DATABASE=neondb
NEON_PORT=5432
NEON_SSL=require
PG_POOL_SIZE=10
PG_IDLE_TIMEOUT=10000
PG_CONNECT_TIMEOUT=5000
PG_STATEMENT_TIMEOUT=30000

# ─── Redis (Upstash) ─────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=  (set via Secret Manager)
# UPSTASH_REDIS_REST_TOKEN=  (set via Secret Manager)

# ─── Sentry ──────────────────────────────────────────────────────
