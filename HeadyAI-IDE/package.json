{
  "name": "headyai-ide",
  "version": "1.0.0",
  "description": "HeadyAI-IDE — Cloud-First AI Development Environment by HeadySystems",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "VITE_MODE=web vite --host --port 3400",
    "build": "vite build",
    "build:web": "VITE_MODE=web vite build --outDir build-web",
    "preview": "vite preview",
    "start": "electron .",
    "start:web": "node server.js",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "package:mac": "electron-builder --mac"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.0",
    "@tailwindcss/postcss": "^4.1.18",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "optionalDependencies": {
    "electron": "^28.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.24",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.headysystems.headyai-ide",
    "productName": "HeadyAI-IDE",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "build/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "HeadyMe",
      "repo": "headyai-ide"
    }
  }
}
