# ==============================================================================
# Heady™ Environment Variables Template
# Generated 2026-03-21 — Every var referenced across the entire codebase
# Copy to .env and fill in values. Lines marked [REQUIRED] must be set.
# ==============================================================================

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
HOST=0.0.0.0

# ─── Authentication & Secrets ─────────────────────────────────────────────────
JWT_SECRET=                          # [REQUIRED] JSON Web Token signing secret
SESSION_SECRET=                      # [REQUIRED] Express session secret
HEADY_API_KEY=                       # [REQUIRED] Internal API key for admin auth
ADMIN_TOKEN=                         # [REQUIRED] Admin login password
API_KEY_SECRET=                      # API key validation secret
ADMIN_TOKEN_HASH=                    # Hashed admin token for gateway auth
INTERNAL_API_KEY=                    # Inter-service communication key

# ─── Google Cloud Platform ────────────────────────────────────────────────────
GCP_PROJECT=heady-prod-609590223909  # GCP project ID
GCP_REGION=us-central1               # GCP region
GCP_SA_KEY=                          # [REQUIRED] Service account JSON key (also GitHub secret)
GCP_ACCESS_TOKEN=                    # Injected by Workload Identity (auto)
CLOUD_RUN_URL=https://heady-manager-609590223909.us-central1.run.app

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                    # [REQUIRED] Google OAuth client ID
GOOGLE_CLIENT_SECRET=                # [REQUIRED] Google OAuth client secret
GOOGLE_REDIRECT_URI=                 # Google OAuth redirect URI

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=                    # GitHub OAuth client ID
GITHUB_CLIENT_SECRET=                # GitHub OAuth client secret

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=            # Firebase service account JSON

# ─── Database (Neon Postgres) ─────────────────────────────────────────────────
DATABASE_URL=                        # [REQUIRED] postgresql://user:pass@host/db?sslmode=require
PGHOST=                              # Postgres host (if not using DATABASE_URL)
PGPORT=6432                          # PgBouncer port
PGDATABASE=heady_vector              # Postgres database name
PGUSER=heady                         # Postgres user
PGPASSWORD=                          # Postgres password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=                           # [REQUIRED] redis://user:pass@host:port

# ─── NATS ─────────────────────────────────────────────────────────────────────
NATS_URL=nats://nats.heady-internal:4222

# ─── AI / LLM Providers ──────────────────────────────────────────────────────
OPENAI_API_KEY=                      # [REQUIRED] OpenAI API key
ANTHROPIC_API_KEY=                   # [REQUIRED] Anthropic (Claude) API key
GROQ_API_KEY=                        # Groq API key (fast inference)

# ─── Vector Search (Pinecone) ─────────────────────────────────────────────────
PINECONE_API_KEY=                    # Pinecone API key
PINECONE_INDEX=task-router           # Pinecone index name

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                   # Stripe secret key
STRIPE_WEBHOOK_SECRET=               # Stripe webhook endpoint secret
STRIPE_PRICE_PRO=                    # Stripe price ID for Pro tier
STRIPE_PRICE_ENTERPRISE=             # Stripe price ID for Enterprise tier

# ─── Cloudflare ───────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=                # Cloudflare API token
CLOUDFLARE_ZONE_ID=                  # Cloudflare zone ID
CLOUDFLARE_ACCOUNT_ID=               # Cloudflare account ID

# ─── Edge / Diffusion ────────────────────────────────────────────────────────
EDGE_DIFFUSION_URL=https://api-inference.huggingface.co/models/stabilityai/stable-diffusion-xl-base-1.0
HUGGINGFACE_API_KEY=                 # HuggingFace inference API key

# ─── Notifications ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=                   # Slack incoming webhook for alerts
SENDGRID_API_KEY=                    # SendGrid email API key

# ─── Service Discovery (Consul) ──────────────────────────────────────────────
CONSUL_HOST=consul
CONSUL_PORT=8500

# ─── Monitoring ───────────────────────────────────────────────────────────────
HEALTH_CHECK_SERVICES=               # Comma-separated list of service URLs to check
VECTOR_OPTIMIZE_URL=                 # Vector optimization endpoint
BRAIN_NODE_ID=local                  # Brain node identifier

# ─── Domain URLs (override defaults) ─────────────────────────────────────────
HEADY_API_URL=https://heady-manager-609590223909.us-central1.run.app
HEADY_MCP_URL=https://headymcp.com
HEADY_BUDDY_URL=https://headybuddy.org
HEADY_AI_URL=https://heady-ai.com
HEADY_IO_URL=https://headyio.com
HEADY_BOT_URL=https://headybot.com
HEADY_SYSTEMS_URL=https://headysystems.com
HEADY_ME_URL=https://headyme.com
HEADY_CONNECTION_URL=https://headyconnection.org

# ─── Config ───────────────────────────────────────────────────────────────────
HEADY_SECRETS=                       # Comma-separated GCP Secret Manager IDs
HEADY_CONFIG_FILE=/etc/heady/config.json

# ─── Generic OAuth2 (optional) ────────────────────────────────────────────────
OAUTH2_TOKEN_ENDPOINT=
OAUTH2_CLIENT_ID=
