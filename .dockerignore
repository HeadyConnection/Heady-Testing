tests
notebooks
docs
*.test.js
*.test.ts
*.test.mjs
*.spec.js
*.spec.ts
*.md
!README.md

# Deployment configs (not part of app)
deployment
heady-build
heady-deploy
heady-improvements
heady-latent-os-runtime-bundle
heady-monorepo
heady-10-10
drupal

# Large non-runtime directories
sacred-projections
perplexity-build
platform-fixes
heady-platform-fixes
tool_calls
reports
templates
scripts
codex-wt-*
sites
infra
infrastructure
envoy
nginx
DockerDesktopWSL
HeadyAI-IDE
AndroidSDK
headybuddy
headybrowser-desktop
archive
extensions
distribution
ventoy
data
logs
audit
E
frontend

# Docker files (not needed inside container)
docker-compose*.yml
Dockerfile*
!Dockerfile.universal

# Large binary assets
*.mp4
*.mp3
*.wav
*.zip
*.tar.gz
*.tgz
*.woff2
*.ttf
*.webp
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
lfs-assets

# Secrets
.env
.env.*
!.env.example
.heady/gcp-*.json
.heady/vault-seed.js

# Misc
*.log
Thumbs.db
.DS_Store
desktop.ini
